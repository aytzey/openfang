# Pulsivo Salesman Environment Variables
# Copy this file to .env and fill in your values.
# Only set the providers you plan to use.

# ─── LLM Provider API Keys ───────────────────────────────────────────

# Anthropic (Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...          # Alternative to GEMINI_API_KEY

# OpenAI
# OPENAI_API_KEY=sk-...

# Groq (fast inference)
# GROQ_API_KEY=gsk_...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# OpenRouter (multi-provider gateway)
# OPENROUTER_API_KEY=sk-or-...

# Together AI
# TOGETHER_API_KEY=...

# Mistral AI
# MISTRAL_API_KEY=...

# Fireworks AI
# FIREWORKS_API_KEY=...

# ─── Local LLM Providers (no API key needed) ─────────────────────────

# Ollama (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# vLLM (default: http://localhost:8000)
# VLLM_BASE_URL=http://localhost:8000

# LM Studio (default: http://localhost:1234)
# LMSTUDIO_BASE_URL=http://localhost:1234

# ─── Channel Tokens ──────────────────────────────────────────────────

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-...

# Discord
# DISCORD_BOT_TOKEN=...

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# WhatsApp (via Cloud API)
# WHATSAPP_TOKEN=...
# WHATSAPP_PHONE_ID=...

# Signal
# SIGNAL_CLI_PATH=/usr/local/bin/signal-cli
# SIGNAL_PHONE_NUMBER=+1...

# Matrix
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=...

# Email (IMAP/SMTP)
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_USERNAME=...
# EMAIL_PASSWORD=...

# ─── Pulsivo Salesman Configuration ──────────────────────────────────────────

# API server bind address.
# Native and Docker Compose default both use 127.0.0.1:4200.
# The compose stack runs with host networking, so the daemon stays localhost-only.
# PULSIVO_SALESMAN_LISTEN=127.0.0.1:4200

# API key for HTTP authentication (leave empty for localhost-only access)
# PULSIVO_SALESMAN_API_KEY=

# Docker Compose host bind mount for persistent runtime files.
# PULSIVO_SALESMAN_DATA_DIR=./.docker/pulsivo-salesman-home

# Docker Compose host bind mount for Codex CLI auth.
# By default the compose file mounts ${HOME}/.codex into /data/.codex.
# PULSIVO_SALESMAN_CODEX_DIR=/home/you/.codex

# Pulsivo Salesman stores state under $HOME/.pulsivo-salesman.
# In Docker Compose, HOME is set to /data, so runtime state lives at /data/.pulsivo-salesman.

# Log level (default: info)
# RUST_LOG=info
# RUST_LOG=pulsivo-salesman=debug        # Debug Pulsivo Salesman only

# Docker Compose uses host networking, so host-local inference endpoints stay on localhost.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# VLLM_BASE_URL=http://127.0.0.1:8000
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234
